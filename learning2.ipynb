     "text": [
      "a= 10\n",
      "a= hello_world\n"
     ]
    }
   ],
   "source": [
    "a = 10 \n",
    "print(\"a=\", a)\n",
    "a = \"hello_world\"\n",
    "print (\"a=\",a)\n"
